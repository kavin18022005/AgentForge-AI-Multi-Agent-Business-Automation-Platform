# AgentForge AI Environment Variables

# Database
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=agentforge_secret
POSTGRES_DB=agentforge_db
DATABASE_URL=postgresql+asyncpg://agentforge:agentforge_secret@localhost:5432/agentforge_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI APIs
GEMINI_API_KEY=your-google-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here-optional

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Supabase (optional - for cloud storage)
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=agentforge-uploads

# App Settings
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
